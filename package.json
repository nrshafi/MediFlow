{
  "name": "mediflow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "dev": "npm run dev --workspace @mediflow/frontend",
    "dev:api": "npm run dev --workspace @mediflow/backend"
  }
}
