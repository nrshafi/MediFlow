{
  "name": "@mediflow/backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:seed": "node --env-file=.dev.vars --import tsx src/db/seed-cli.ts",
    "dev": "wrangler dev",
    "test": "node --import tsx --test src/db/seed.test.ts src/engine/baseline.test.ts src/engine/scheduler.test.ts src/llm/adapter.test.ts src/llm/integration.test.ts src/routes/reset.test.ts src/simulation/clock.test.ts src/simulation/day.test.ts"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@mediflow/shared": "0.0.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260714.1",
    "@types/node": "24.10.10",
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "wrangler": "4.110.0"
  }
}
